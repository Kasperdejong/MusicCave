{
  "manifest_version": 3,
  "name": "MusicCave",
  "version": "1.1",
  "key": "",
  "description": "Connects MusicCave React App to Apple Music & Spotify DOM.",
  "permissions":[
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts":[
    {
      "matches": ["https://music.apple.com/*", "https://open.spotify.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "LogoMusicCave.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://music-cave.vercel.app/*" 
    ]
  }
}